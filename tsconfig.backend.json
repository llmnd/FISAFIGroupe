{
  "compilerOptions": {
    "outDir": "./dist/backend",
    "rootDir": "./backend",
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2020",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "types": ["node"]
  },
  "include": ["backend/**/*"],
  "exclude": ["node_modules", "pages", "components", "styles", "public"]
}
