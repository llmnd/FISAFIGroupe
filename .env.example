# .env.example - Copy this to .env.local and fill in your values

# Database (required - get from https://console.neon.tech/)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# JWT Secret (required - generate a long random string)
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="your-super-secret-jwt-key-min-32-chars"

# Cloudinary (required on BACKEND only, not here)
# Configure on Render backend environment or backend/.env.backend
