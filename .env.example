# .env.example - Copy this to .env.local and fill in your values

# Database (required - get from https://console.neon.tech/)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# JWT Secret (required - generate a long random string)
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="your-super-secret-jwt-key-min-32-chars"

# Cloudinary (required for image/document uploads)
# Get from: https://cloudinary.com/console/settings
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_UPLOAD_PRESET="your-unsigned-upload-preset"
# Optional: For admin operations (deletion, etc.)
# CLOUDINARY_API_KEY="your-api-key"
# CLOUDINARY_API_SECRET="your-api-secret"
