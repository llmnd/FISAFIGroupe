# .env.production.example
# Copy this to .env.production and fill in the values for production

# Database
DATABASE_URL="postgresql://user:password@host:5432/fisafi_prod"

# Server
BACKEND_PORT=3001
BACKEND_HOST="0.0.0.0"
NODE_ENV="production"

# JWT
JWT_SECRET="CHANGE_THIS_TO_A_LONG_RANDOM_STRING_IN_PRODUCTION!"
JWT_EXPIRATION="7d"

# CORS
FRONTEND_URL="https://your-domain.com"
